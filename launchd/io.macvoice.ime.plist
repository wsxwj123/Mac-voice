<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- 替换 __PYTHON__ 和 __PROJECT_DIR__ 为绝对路径后使用。
     可选：在 EnvironmentVariables 里加 VOICE_IME_DEVICE 锁定麦克风。 -->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>io.macvoice.ime</string>
  <key>ProgramArguments</key>
  <array>
    <string>__PYTHON__</string>
    <string>__PROJECT_DIR__/voice_ime.py</string>
  </array>
  <key>WorkingDirectory</key>
  <string>__PROJECT_DIR__</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ProcessType</key>
  <string>Interactive</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PYTHONUNBUFFERED</key>
    <string>1</string>
  </dict>
  <key>StandardOutPath</key>
  <string>__PROJECT_DIR__/logs/ime.out.log</string>
  <key>StandardErrorPath</key>
  <string>__PROJECT_DIR__/logs/ime.err.log</string>
</dict>
</plist>
